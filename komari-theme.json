{
  "name": "Ran · 岚",
  "short": "ran",
  "description": "精密金工质感 · 双 hairline 倒角 · 凹陷读数窗 · 蚀刻铭牌字 · 双主题(墨石深 / 雾色浅)。Inspired by precision-machined hi-fi gear.",
  "version": "0.7.0",
  "author": "Miuler",
  "url": "https://github.com/saladinxp/komari-ran-theme",
  "preview": "preview.png",
  "configuration": {
    "type": "managed",
    "name": "[ 岚 / RAN ] 主题配置",
    "data": [
      {
        "name": "◇ THEME // 主题",
        "type": "title"
      },
      {
        "key": "default_theme",
        "name": "[ MODE ] 默认主题",
        "type": "string",
        "default": "ran-night",
        "help": "页面首次加载时的默认主题。可选 ran-night(墨石,深色)或 ran-mist(雾色,浅色)。用户切换后浏览器会记住偏好。"
      },
      {
        "key": "version_tag",
        "name": "[ SYS.VER ] 版本号",
        "type": "string",
        "default": "v0.7.0",
        "help": "页脚显示的版本标识"
      },
      {
        "name": "◇ INFO // 站点",
        "type": "title"
      },
      {
        "key": "site_name",
        "name": "[ SITE ] 站点名称",
        "type": "string",
        "default": "岚 · Komari",
        "help": "顶部显示的站点名,留空则使用 Komari /api/public 的 site_name"
      },
      {
        "key": "footer_text",
        "name": "[ FOOTER ] 页脚文字",
        "type": "string",
        "default": "POWERED BY KOMARI",
        "help": "页脚右侧文字"
      }
    ]
  }
}
