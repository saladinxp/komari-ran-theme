{
  "name": "Ran · 岚",
  "short": "ran",
  "description": "精密金工质感 · 双 hairline 倒角 · 凹陷读数窗 · 蚀刻铭牌字 · 双主题(墨石深 / 雾色浅)。Inspired by precision-machined hi-fi gear.",
  "version": "0.9.6",
  "author": "Miuler",
  "url": "https://github.com/saladinxp/komari-ran-theme",
  "preview": "preview.png",
  "configuration": {
    "type": "managed",
    "name": "[ 岚 / RAN ] 主题配置",
    "data": [
      {
        "name": "◇ THEME // 主题",
        "type": "title"
      },
      {
        "key": "default_theme",
        "name": "[ MODE ] 默认主题",
        "type": "select",
        "options": "ran-night,ran-mist",
        "default": "ran-night",
        "help": "页面首次加载时的默认主题。ran-night = 墨石(深色),ran-mist = 雾色(浅色)。用户切换后浏览器会记住偏好。"
      },
      {
        "key": "version_tag",
        "name": "[ SYS.VER ] 版本号",
        "type": "string",
        "default": "v0.9.6",
        "help": "页脚显示的版本标识"
      },
      {
        "name": "◇ INFO // 站点",
        "type": "title"
      },
      {
        "key": "site_name",
        "name": "[ SITE ] 站点名称",
        "type": "string",
        "default": "岚 · Komari",
        "help": "顶部显示的站点名,留空则使用 Komari /api/public 的 site_name"
      },
      {
        "key": "footer_text",
        "name": "[ FOOTER ] 页脚文字",
        "type": "string",
        "default": "POWERED BY KOMARI",
        "help": "页脚右侧文字"
      },
      {
        "name": "◇ BEIAN // 备案",
        "type": "title"
      },
      {
        "key": "icp_text",
        "name": "[ ICP ] ICP 备案号",
        "type": "string",
        "default": "",
        "help": "工信部 ICP 备案编号,例如 浙ICP备12345678号-1。留空则不显示。"
      },
      {
        "key": "icp_url",
        "name": "[ ICP ] ICP 备案链接",
        "type": "string",
        "default": "https://beian.miit.gov.cn",
        "help": "ICP 备案号的跳转链接。留空则备案号显示为纯文本不可点击。"
      },
      {
        "key": "police_text",
        "name": "[ 公安 ] 公网安备号",
        "type": "string",
        "default": "",
        "help": "公安备案编号,例如 浙公网安备 33010602012345号。留空则不显示。"
      },
      {
        "key": "police_url",
        "name": "[ 公安 ] 公网安备链接",
        "type": "string",
        "default": "https://beian.mps.gov.cn",
        "help": "公网安备号的跳转链接。留空则备案号显示为纯文本不可点击。"
      }
    ]
  }
}
